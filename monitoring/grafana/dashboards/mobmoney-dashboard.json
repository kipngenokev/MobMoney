{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "MobMoney Overview",
  "uid": "mobmoney-overview",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Transfer outcomes (rate /s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "rate(mobmoney_transfers_completed_total[1m])", "legendFormat": "completed" },
        { "expr": "rate(mobmoney_transfers_failed_total[1m])", "legendFormat": "failed" },
        { "expr": "rate(mobmoney_transfers_initiated_total[1m])", "legendFormat": "initiated" }
      ]
    },
    {
      "id": 2,
      "title": "Idempotent replays & compensations (rate /s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "rate(mobmoney_idempotent_replays_total[1m])", "legendFormat": "replays" },
        { "expr": "rate(mobmoney_compensations_total[1m])", "legendFormat": "compensations" }
      ]
    },
    {
      "id": 3,
      "title": "Transfer duration p95 (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(mobmoney_transfer_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP request rate by status",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{application=\"transfer-service\"}[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "JVM heap used (transfer-service)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"transfer-service\", area=\"heap\"})",
          "legendFormat": "heap used"
        }
      ]
    },
    {
      "id": 6,
      "title": "Partner settlement HTTP outcomes",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{application=\"partner-bank-service\"}[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ]
}
